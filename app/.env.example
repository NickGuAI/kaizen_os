# Example Environment Configuration - Kaizen OS
# Copy this file to .env.test or .env.prod and fill in the values

# Supabase Configuration (Client-Safe)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe Keys (Server-Side Only)
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_key_here
STRIPE_SECRET_KEY=sk_test_or_sk_live_key_here
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Application URL
APP_URL=http://localhost:3000

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
