{
  "name": "kaizen-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:cleanup": "(lsof -ti :3000 -ti :3001 | xargs kill -9 2>/dev/null) || true",
    "dev:all": "npm run dev:cleanup && concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "prisma generate && tsc -b && vite build",
    "start:prod": "tsx src/server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/pubsub": "^5.3.0",
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^5.6.0",
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.60.0",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "@types/luxon": "^3.7.1",
    "animejs": "^4.2.2",
    "argon2": "^0.41.1",
    "bootstrap": "^5.3.8",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "googleapis": "^169.0.0",
    "lenis": "^1.3.18-dev.0",
    "lowlight": "^3.3.0",
    "luxon": "^3.7.2",
    "motion": "^12.34.4",
    "ogl": "^1.0.11",
    "posthog-js": "^1.335.2",
    "react": "^18.3.1",
    "react-big-calendar": "^1.19.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^17.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/animejs": "^3.1.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
