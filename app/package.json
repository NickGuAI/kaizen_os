    "globals": "^15.12.0",
    "postcss": "^8.5.6",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^2.1.0"
  }
}
